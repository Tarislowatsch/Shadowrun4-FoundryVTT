<div class="flow-settings-menu" style="display:flex; flex-direction:column; gap:12px; padding:8px; box-sizing:border-box;">
  <p class="hint" style="margin:0;">{{localize "sr4.settings.flowSettingsMenu.hint"}}</p>

  {{#unless isGM}}
  <p class="notification warning" style="margin:0;">{{localize "sr4.settings.flowSettingsMenu.playerNotice"}}</p>
  {{/unless}}

  {{#each sections}}
  <fieldset style="border:1px solid var(--color-border-light-tertiary); border-radius:4px; padding:8px; display:flex; flex-direction:column; gap:8px;">
    <legend style="padding:0 4px; font-weight:bold;">{{localize this.label}}</legend>
    {{#each this.fields}}
    <div class="form-group flexcol"
      {{#if this.custom}}data-flow-custom{{/if}}
      style="gap:2px; {{#if this.hidden}}display:none;{{/if}}">
      <div style="display:flex; align-items:center; gap:8px;">
        <label style="flex:1;">{{localize this.name}}</label>
        {{#if (eq this.type "checkbox")}}
        <input type="checkbox" name="{{this.key}}" {{#if this.checked}}checked{{/if}}
          {{#if this.disabled}}disabled{{/if}} />
        {{else if (eq this.type "select")}}
        <select name="{{this.key}}" style="flex:2;"
          {{#if this.controller}}data-flow-controller{{/if}}
          {{#if this.disabled}}disabled{{/if}}>
          {{#each this.choices}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{localize this.label}}</option>
          {{/each}}
        </select>
        {{else if (eq this.type "number")}}
        <input type="number" name="{{this.key}}" value="{{this.value}}" style="flex:2;"
          min="{{this.min}}" max="{{this.max}}" step="{{this.step}}"
          {{#if this.disabled}}disabled{{/if}} />
        {{else}}
        <input type="text" name="{{this.key}}" value="{{this.value}}" style="flex:2;"
          {{#if this.disabled}}disabled{{/if}} />
        {{/if}}
      </div>
      <p class="hint" style="margin:0;">{{localize this.hint}}</p>
    </div>
    {{/each}}
  </fieldset>
  {{/each}}

  <footer class="sheet-footer flexrow" style="margin-top:8px; gap:8px; flex-shrink:0;">
    <button type="button" data-action="save">
      <i class="fas fa-save"></i> {{localize "sr4.settings.flowSettingsMenu.save"}}
    </button>
    <button type="button" data-action="reset">
      <i class="fas fa-rotate-left"></i> {{localize "sr4.settings.flowSettingsMenu.reset"}}
    </button>
  </footer>
</div>
