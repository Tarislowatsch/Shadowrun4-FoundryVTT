<div class="sr4-character-importer" style="display:flex; flex-direction:column; padding:8px; box-sizing:border-box; gap:8px;">
  <p style="margin:0; opacity:0.8;">{{localize "sr4.characterImporter.hint"}}</p>

  <label style="display:flex; flex-direction:column; gap:4px;">
    <strong>{{localize "sr4.characterImporter.upload"}}</strong>
    <input type="file" data-file accept=".xml" />
  </label>

  {{#if hasData}}
    <fieldset style="margin:0; padding:8px; border:1px solid var(--color-border-light-tertiary, #999); border-radius:4px;">
      <legend>{{localize "sr4.characterImporter.preview"}}</legend>
      <div style="display:flex; gap:10px; align-items:flex-start;">
        {{#if portrait}}
          <img src="{{portrait}}" alt="" style="width:64px; height:64px; object-fit:cover; border-radius:4px; flex-shrink:0;" />
        {{/if}}
        <div style="flex:1;">
          <div style="font-weight:bold; font-size:1.1em;">{{name}}</div>
          <div style="opacity:0.8;">{{metatype}}</div>
          <div style="opacity:0.7; font-size:0.9em; margin-top:2px;">
            {{localize "sr4.characterImporter.itemCount"}}: {{itemCount}} ·
            {{localize "sr4.characterImporter.skillCount"}}: {{skillCount}}
          </div>
        </div>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:2px 10px; margin-top:6px; font-size:0.85em;">
        {{#each attributes}}
          <span><strong>{{key}}</strong> {{value}}</span>
        {{/each}}
      </div>
    </fieldset>
  {{/if}}

  <footer class="sheet-footer flexrow" style="flex-shrink:0;">
    <button type="button" data-action="import" {{#unless hasData}}disabled{{/unless}}>
      <i class="fas fa-user-plus"></i> {{localize "sr4.characterImporter.import"}}
    </button>
  </footer>
</div>
