<form class="item-form effect" autocomplete="off">
  <div class="item-sheet-body">

    <header class="item-sheet-header">
      <div class="effect-img-picker">
        <img
          src="{{img}}"
          class="effect-header-img"
          data-action="pickImage"
          data-tooltip="{{localize 'sr4.effect.changeIcon'}}"
        />
        <input type="hidden" name="img" value="{{img}}" />
      </div>
      <div class="item-sheet-name">
        <label>{{localize "sr4.effect.name"}}</label>
        <input type="text" name="name" value="{{name}}" />
      </div>
      <div class="item-sheet-header-extras">
        <label>
          {{localize "sr4.effect.active"}}
          <input type="checkbox" class="sr4-checkbox" name="active" {{#if active}}checked{{/if}} />
        </label>
        <label>
          {{localize "sr4.effect.showOnToken"}}
          <input type="checkbox" class="sr4-checkbox" name="showOnToken" {{#if showOnToken}}checked{{/if}} />
        </label>
        <label>
          {{localize "sr4.effect.isTemplate"}}
          <input type="checkbox" class="sr4-checkbox" name="isTemplate" {{#if isTemplate}}checked{{/if}} />
        </label>
        <label>
          {{localize "sr4.effect.duration"}}
          <input type="number" name="durationTurns" value="{{durationTurns}}" min="0" />
        </label>
      </div>
    </header>

    <table class="item-stats-table">
      <thead>
        <tr>
          <th>{{localize "sr4.effect.attribute"}}</th>
          <th>{{localize "sr4.effect.mode.label"}}</th>
          <th>{{localize "sr4.effect.value"}}</th>
          <th class="change-controls-col">
            <a data-action="addChange" data-tooltip="{{localize 'sr4.effect.addChange'}}">
              <i class="fas fa-plus"></i>
            </a>
          </th>
        </tr>
      </thead>
      <tbody class="changes-body">
        {{#each changes as |change|}}
        <tr class="change-row">
          <td>
            <select name="changeKey">
              {{selectOptions @root.effectTargets selected=change.key localize=true}}
            </select>
          </td>
          <td>
            <select name="changeMode">
              {{selectOptions @root.changeModes selected=change.mode localize=true}}
            </select>
          </td>
          <td>
            <input type="number" name="changeValue" value="{{change.value}}" />
          </td>
          <td class="change-controls">
            <a class="remove-change-btn" data-action="removeChange"
              data-tooltip="{{localize 'sr4.effect.removeChange'}}"
              {{#unless @root.multipleChanges}}style="visibility:hidden"{{/unless}}>
              <i class="fas fa-times"></i>
            </a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="item-textareas">
      <div>
        <label>{{localize "sr4.effect.notes"}}</label>
        <textarea
          name="description"
          placeholder="{{localize 'sr4.effect.notes'}}"
        >{{description}}</textarea>
      </div>
    </div>

    <footer class="effect-config-footer">
      <button type="button" data-action="saveEffect">
        <i class="fas fa-save"></i> {{localize "Save Changes"}}
      </button>
    </footer>

  </div>
</form>
