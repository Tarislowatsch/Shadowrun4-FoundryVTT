<div class="tab main sheet-container {{tab.cssClass}}" data-group="primary" data-tab="main">

  <h3>{{localize 'sr4.vehicle.stats'}}</h3>
  <div class="grid">
    {{#each vehicleStats as |stat|}}
      {{> "attribute-cell" label=stat.label name=stat.name value=stat.value sourceValue=stat.sourceValue}}
    {{/each}}
  </div>

  <div class="item-card-actions drone-actions">
    <button type="button" class="roll-action" data-action="droneAction" data-drone-action="maneuvering">
      <i class="fas fa-route"></i> {{localize 'sr4.vehicle.actions.maneuvering'}}
    </button>
    <button type="button" class="roll-action" data-action="droneAction" data-drone-action="perception">
      <i class="fas fa-eye"></i> {{localize 'sr4.vehicle.actions.perception'}}
    </button>
    <button type="button" class="roll-action" data-action="droneAction" data-drone-action="infiltration">
      <i class="fas fa-user-ninja"></i> {{localize 'sr4.vehicle.actions.infiltration'}}
    </button>
  </div>

  <hr />

  <div class="monitor-tracks">
    {{> "status-track-card"
        title="sr4.conditionMonitor.physical"
        type="physical"
        max=system.conditionMonitor.physical.max
        current=system.conditionMonitor.physical.value}}
    <div class="vehicle-pilot-info">
      <span class="pilot-label">{{localize 'sr4.vehicle.pilotPoolHint'}}</span>
      <span class="pilot-value">{{system.pilot}} + autosoft</span>
    </div>
  </div>

  <hr />

  <div class="npc-section">
    <h3>{{localize 'sr4.vehicle.autosofts'}}</h3>
    {{#if autosofts}}
      {{#each autosofts as |autosoft|}}
      <div class="item-card" data-item-id="{{autosoft._id}}">
        <div class="item-row">
          <span class="item-name">{{autosoft.name}}</span>
          <span class="item-property">{{autosoft.system.autosoftType}}</span>
          <span class="item-property">{{autosoft.system.rating}}</span>
          {{#if autosoft.system.target}}
            <span class="item-property">{{autosoft.system.target}}</span>
          {{/if}}
          <button type="button" class="roll-action" data-action="rollAutonomous" data-item-id="{{autosoft._id}}"
            data-tooltip="{{localize 'sr4.vehicle.rollAutonomous'}}">
            <i class="fas fa-dice-d6"></i>
          </button>
          {{> item-edit-btn itemId=autosoft._id}}
          {{> item-delete-btn itemId=autosoft._id}}
        </div>
      </div>
      {{/each}}
    {{else}}
      <p class="empty-list">{{localize 'sr4.vehicle.noAutosofts'}}</p>
    {{/if}}
  </div>

  <div class="npc-section">
    <div class="tab-header">
      <h3>{{localize 'sr4.vehiclemod.mods'}}</h3>
      {{> item-create-btn btnAction="createVehicleMod" btnTooltip="sr4.vehiclemod.add"}}
    </div>
    <small>{{localize 'sr4.vehiclemod.slotsUsed'}}: {{ usedSlots }} / {{ system.body }}
      {{#if slotWarning}}
        <i class="fas fa-exclamation-triangle warning" data-tooltip="{{localize 'sr4.vehiclemod.slotWarning'}}"></i>
      {{/if}}
    </small>
    {{#if vehicleMods}}
      {{#each vehicleMods as |mod|}}
      <div class="item-card" data-item-id="{{mod.id}}">
        <div class="item-row">
          <span class="item-name">{{mod.name}}</span>
          <span class="item-property">{{localize 'sr4.vehiclemod.slotCost'}}: {{mod.system.slotCost}}</span>
          {{> item-edit-btn itemId=mod.id}}
          {{> item-delete-btn itemId=mod.id}}
        </div>
      </div>
      {{/each}}
    {{else}}
      <p class="empty-list">{{localize 'sr4.vehiclemod.noMods'}}</p>
    {{/if}}
  </div>

  <div class="npc-section">
    <h3>{{localize 'sr4.tab.weapons'}}</h3>
    {{#if weapons}}
      {{#each weapons as |weapon|}}
      <div class="item-card" data-item-id="{{weapon._id}}">
        <div class="item-row">
          <span class="item-name">{{weapon.name}}</span>
          <span class="item-property">{{weapon.system.damage}}</span>
          <button type="button" class="roll-action" data-action="attackRoll" data-item-id="{{weapon._id}}"
            data-tooltip="{{localize 'sr4.vehicle.rollAutonomous'}}">
            <i class="fas fa-crosshairs"></i>
          </button>
          {{> item-edit-btn itemId=weapon._id}}
          {{> item-delete-btn itemId=weapon._id}}
        </div>
      </div>
      {{/each}}
    {{else}}
      <p class="empty-list">{{localize 'sr4.weapon.noWeapons'}}</p>
    {{/if}}
  </div>

</div>
