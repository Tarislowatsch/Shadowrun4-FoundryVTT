<div class="npc-section">
  <h3>
    {{localize 'sr4.critterPower.powers'}}
    {{#if editMode}}{{> item-create-btn btnAction="createItem" btnItemType="CritterPower" btnTooltip="sr4.critterPower.powers"}}{{/if}}
  </h3>
  {{#if critterPowers.length}}
    {{#each critterPowers as |power|}}
    <div class="item-card power-card" data-item-id="{{power._id}}">
      <div class="item-row">
        <span class="item-name">{{power.name}}</span>
        {{#if power.system.source}}<span class="item-source">{{power.system.source}}</span>{{/if}}
        {{> item-source-btn source=power.system.source}}
        {{> item-edit-btn itemId=power._id}}
        {{> item-delete-btn itemId=power._id}}
      </div>
      {{> item-card-actions-effects}}
    </div>
    {{/each}}
  {{else}}
    <p class="empty-list">{{localize 'sr4.critterPower.noPowers'}}</p>
  {{/if}}
</div>
