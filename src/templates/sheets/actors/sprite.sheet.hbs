<div class="sheet-container">

  <div class="npc-header">
    {{> "actor-image"}}
    <div class="npc-header-info">
      <div class="meta-field">
        <label>{{localize 'sr4.sprite.name'}}</label>
        <input type="text" name="name" value="{{actor.name}}" {{#unless editMode}}readonly{{/unless}} />
      </div>
      <div class="meta-field">
        <label>{{localize 'sr4.sprite.type'}}</label>
        <input type="text" name="system.spriteType" value="{{system.spriteType}}" {{#unless editMode}}readonly{{/unless}} />
      </div>
      <div class="meta-field">
        <label>{{localize 'sr4.sprite.rating'}}</label>
        <input type="number" name="system.rating" value="{{system.rating}}" {{#unless editMode}}readonly{{/unless}} />
      </div>
      <div class="meta-field">
        <label>{{localize 'sr4.sprite.tasks'}}</label>
        <input type="number" name="system.tasks" value="{{system.tasks}}" />
      </div>
    </div>
  </div>

  <div class="actor-link-row">
    <label>{{localize 'sr4.sprite.compiler'}}</label>
    <div class="actor-drop-zone" data-drop-type="ownerUuid">
      {{#if ownerName}}
        <span class="linked-actor-name">{{ownerName}}</span>
        {{#if editMode}}
          <button type="button" class="link-clear" data-action="clearOwner"><i class="fas fa-times"></i></button>
        {{/if}}
      {{else}}
        <span class="drop-hint">{{localize 'sr4.sprite.dropCompiler'}}</span>
      {{/if}}
    </div>
  </div>

  <hr />

  <h3>{{localize 'sr4.sprite.attributes'}}</h3>
  <div class="grid">
    {{#each sheetStats as |stat|}}
      {{> "attribute-cell" label=stat.label name=stat.name value=stat.value rollLabel=stat.rollLabel}}
    {{/each}}
  </div>

  <hr />

  <div class="monitor-tracks">
    {{> "status-track-card"
        title="sr4.conditionMonitor.physical"
        type="physical"
        max=system.conditionMonitor.physical.max
        current=system.conditionMonitor.physical.value}}
    {{> "status-track-card"
        title="sr4.conditionMonitor.stun"
        type="stun"
        max=system.conditionMonitor.stun.max
        current=system.conditionMonitor.stun.value}}
  </div>

  <hr />

  {{> "critter-powers" critterPowers=critterPowers editMode=editMode}}

  <div class="npc-section">
    <h3>{{localize 'sr4.tab.skills'}}</h3>
    {{#if skills}}
      {{#each skills as |skill|}}
      <div class="item-card" data-item-id="{{skill._id}}">
        <div class="item-row">
          <span class="item-name roll-skill" data-action="rollSkill" data-skill-name="{{skill.name}}">{{skill.name}}</span>
          <span class="item-property">{{skill.system.rating}}</span>
          {{> item-edit-btn itemId=skill._id}}
          {{> item-delete-btn itemId=skill._id}}
        </div>
      </div>
      {{/each}}
    {{else}}
      <p class="empty-list">{{localize 'sr4.sprite.noSkills'}}</p>
    {{/if}}
  </div>

  <div class="npc-section">
    <h3>{{localize 'sr4.item.notes'}}</h3>
    <textarea name="system.notes">{{ system.notes }}</textarea>
  </div>

</div>
