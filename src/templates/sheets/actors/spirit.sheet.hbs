<div class="sheet-container">

  <div class="npc-header">
    {{> "actor-image"}}
    <div class="npc-header-info">
      <div class="meta-field">
        <label>{{localize 'sr4.spirit.name'}}</label>
        <input type="text" name="name" value="{{actor.name}}" {{#unless editMode}}readonly{{/unless}} />
      </div>
      <div class="meta-field">
        <label>{{localize 'sr4.spirit.type'}}</label>
        <input type="text" name="system.spiritType" value="{{system.spiritType}}" {{#unless editMode}}readonly{{/unless}} />
      </div>
      <div class="meta-field">
        <label>{{localize 'sr4.spirit.force'}}</label>
        <input type="number" name="system.force" value="{{system.force}}" {{#unless editMode}}readonly{{/unless}} />
      </div>
      <div class="meta-field">
        <label>{{localize 'sr4.spirit.services'}}</label>
        <input type="number" name="system.services" value="{{system.services}}" />
      </div>
    </div>
  </div>

  {{> "actor-link-row"
      linkLabel="sr4.spirit.summoner"
      dropType="ownerUuid"
      linkedName=ownerName
      clearAction="clearOwner"
      dropHint="sr4.spirit.dropSummoner"}}

  <hr />

  <h3>{{localize 'sr4.spirit.attributes'}}</h3>
  <div class="grid">
    {{#each sheetStats as |stat|}}
      {{> "attribute-cell" label=stat.label name=stat.name value=stat.value sourceValue=stat.sourceValue rollLabel=stat.rollLabel}}
    {{/each}}
  </div>

  <hr />

  <div class="monitor-tracks">
    {{> "status-track-card"
        title="sr4.conditionMonitor.physical"
        type="physical"
        max=system.conditionMonitor.physical.max
        current=system.conditionMonitor.physical.value}}
    {{> "status-track-card"
        title="sr4.conditionMonitor.stun"
        type="stun"
        max=system.conditionMonitor.stun.max
        current=system.conditionMonitor.stun.value}}
  </div>

  <hr />

  {{> "critter-powers" critterPowers=critterPowers editMode=editMode}}

  {{> "npc-skills-section" skills=skills emptyKey="sr4.spirit.noSkills"}}

  <div class="npc-section">
    <h3>{{localize 'sr4.item.notes'}}</h3>
    <textarea name="system.notes">{{ system.notes }}</textarea>
  </div>

</div>
