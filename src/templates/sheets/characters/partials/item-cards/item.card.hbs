<div
  class="item-card item"
  data-item-id="{{ this._id }}"
  id="{{ this._id }}"
  title="{{ this.system.description }}"
>
  {{> item-card-header}}
  <div class="item-body">
    <span class="item-property">
      <strong>{{localize "sr4.item.rating"}}</strong>
      {{ this.system.rating }}
    </span>
    <span class="item-property">
      <strong>{{localize "sr4.item.legality"}}</strong>
      {{ this.system.legality }}
    </span>
    <span class="item-property">
      <strong>{{localize "sr4.item.cost"}}</strong>
      {{ this.system.cost }}
    </span>
    <span class="item-property">
      <strong>{{localize "sr4.item.quantity"}}</strong>
      <input
        class="item-quantity"
        type="number"
        name="system.quantity"
        value="{{ this.system.quantity }}"
        data-dtype="Number"
      />
    </span>
  </div>
</div>
