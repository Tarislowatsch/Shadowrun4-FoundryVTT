<div class="item-card item focus-card" data-item-id="{{ this._id }}" title="{{ this.system.description }}">
  {{#> item-card-header activeBadgeLabel="sr4.item.equipped"}}
    {{#*inline "card-buttons"}}
      {{> item-toggle-equip equippedIcon="fas fa-link" unequippedIcon="fas fa-link-slash" tooltip="sr4.item.toggleEquip"}}
    {{/inline}}
  {{/item-card-header}}
  <div class="item-body">
    {{#if this.system.rating}}
    <span class="item-property">
      <strong>{{localize "sr4.item.rating"}}</strong>
      {{ this.system.rating }}
    </span>
    {{/if}}
    {{#if this.system.source}}
    <span class="item-property">
      <strong>{{localize "sr4.spell.source"}}</strong>
      {{ this.system.source }}
    </span>
    {{/if}}
  </div>
</div>
