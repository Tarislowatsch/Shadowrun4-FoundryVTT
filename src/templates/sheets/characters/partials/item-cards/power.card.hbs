<div
  class="item-card power-card"
  id="{{ this._id }}"
  data-item-id="{{ this._id }}"
  title="{{ this.system.description }}"
>
  {{> item-card-header}}
  <div class="item-body">
    <span class="item-property">
      <strong>{{localize "sr4.power.totalCost"}}</strong>
      {{ this.system.totalCost }}
    </span>
    <span class="item-property">
      <strong>{{localize "sr4.power.rating"}}</strong>
      {{ this.system.rating }}
    </span>
    {{#if this.system.geas}}
    <span class="item-property">
      <strong>{{localize "sr4.power.geas"}}</strong>
      &#10003;
    </span>
    {{/if}}
    {{#if this.system.source}}
    <span class="item-property">
      <strong>{{localize "sr4.power.source"}}</strong>
      {{ this.system.source }}
    </span>
    {{/if}}
  </div>
  {{> item-card-actions-effects}}
</div>
