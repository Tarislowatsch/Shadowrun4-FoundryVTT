<div
  class="item-card item weapon-card"
  data-item-id="{{ this._id }}"
  id="{{ this._id }}"
>
  <div class="item-header item-row">
    <span class="item-name">
      {{ this.name }}
    </span>

    <div class="item-actions">
      <button
        class="attack roll-action"
        data-action="attackRoll"
        data-attack-skill="{{ this.system.attackSkill }}"
        data-item-id="{{ this._id }}"
        data-tooltip="{{localize 'sr4.weapon.attack'}}"
      >
        <i class="fas fa-bullseye"></i>
      </button>
      {{#if (eq this.type 'Melee Weapon')}}
      {{> item-toggle-equip equippedIcon="fas fa-hand-fist" unequippedIcon="far fa-hand" tooltip="sr4.item.toggleEquip"}}
      {{/if}}
      {{#if (eq this.type 'Ranged Weapon')}}
        {{#if this.system.maxAmmo}}
        <button class="item-reload" data-action="reloadWeapon" data-tooltip="{{localize 'sr4.weapon.reload'}}">
          <i class="fas fa-rotate-right"></i>
        </button>
        {{/if}}
      {{/if}}
      {{> item-edit-btn}}
      {{> item-delete-btn}}
    </div>
  </div>

  <div class="item-body weapon-stats">
    <span class="item-property">
      <strong>{{localize "sr4.weapon.attackSkill"}}</strong>
      {{localize this.displayAttackSkill}}
    </span>

    <span class="item-property">
      <strong>{{localize "sr4.weapon.damage"}}</strong>
      {{#if (eq this.system.effectiveDamage this.system.damage)}}
        {{ this.system.damage }}
      {{else}}
        <span title="{{localize 'sr4.weapon.damage'}}: {{ this.system.damage }}">{{ this.system.effectiveDamage }}</span>
      {{/if}}
    </span>

    <span class="item-property">
      <strong>{{localize "sr4.weapon.damageType"}}</strong>
      {{localize this.displayDamageType}}
    </span>

    <span class="item-property">
      <strong>{{localize "sr4.weapon.ap"}}</strong>
      {{#if (eq this.system.effectiveAP this.system.ap)}}
        {{ this.system.ap }}
      {{else}}
        <span title="{{localize 'sr4.weapon.ap'}}: {{ this.system.ap }}">{{ this.system.effectiveAP }}</span>
      {{/if}}
    </span>

    {{#if (eq this.type 'Ranged Weapon')}}
    <span class="item-property">
      <strong>{{localize "sr4.weapon.mode"}}</strong>
      {{localize this.displayMode}}
    </span>

    {{#if this.system.maxAmmo}}
    <span class="item-property">
      <strong>{{localize "sr4.weapon.ammo"}}</strong>
      {{ this.system.currentAmmo }}/{{ this.system.maxAmmo }}{{#if this.system.ammoFeed}} ({{ this.system.ammoFeed }}){{/if}}
    </span>
    {{/if}}
    {{/if}}
  </div>

  <div class="item-card-mods">
    {{#each this.installedMods as |mod|}}
    <span class="mod-entry">
      <span class="mod-name">{{ mod.name }}</span>
      {{> item-edit-btn itemId=mod.id}}
      <button type="button" class="item-delete" data-action="removeMod" data-mod-id="{{ mod.id }}" data-tooltip="{{localize 'sr4.item.delete'}}"><i class="fas fa-times"></i></button>
    </span>
    {{/each}}
    {{#if this.installedMods.length}}
    <span class="mod-entry">
      <small>{{localize 'sr4.weaponmod.slotsUsed'}}: {{ this.system.usedModSlots }} / {{ this.system.modSlots }}</small>
      {{#if this.system.modSlotWarning}}
        <i class="fas fa-exclamation-triangle warning" data-tooltip="{{localize 'sr4.weaponmod.slotWarning'}}"></i>
      {{/if}}
    </span>
    {{/if}}
    {{#if this.availableWeaponMods.length}}
    <select class="mod-add-select">
      <option value="">+ {{localize 'sr4.weaponmod.add'}}</option>
      {{#each this.availableWeaponMods as |m|}}
      <option value="{{ m.id }}">{{ m.name }}</option>
      {{/each}}
    </select>
    {{/if}}
    {{> item-create-btn btnAction="createMod" btnItemType="Weapon Mod" btnTooltip="sr4.weaponmod.add"}}
  </div>

  {{#if (eq this.type 'Ranged Weapon')}}
  {{#if this.system.maxAmmo}}
  <div class="item-body weapon-ammo">
    {{#if this.loadedAmmo}}
    <button class="item-edit weapon-ammo-edit" data-action="editAmmo" data-ammo-id="{{ this.system.loadedAmmoId }}"
      data-tooltip="{{localize 'sr4.weapon.editAmmo'}}">
      <i class="fas fa-edit"></i>
    </button>
    {{/if}}
    <span class="item-property">
      <strong>{{localize "sr4.ammo.loaded"}}{{> tooltip text=(localize "sr4.tooltip.loadedAmmo")}}</strong>
      <select name="system.loadedAmmoId">
        <option value="">—</option>
        {{#each this.availableAmmo as |a|}}
        <option value="{{ a.id }}" {{#if (eq ../system.loadedAmmoId a.id)}}selected{{/if}}>{{ a.name }}</option>
        {{/each}}
      </select>
    </span>
    <span class="item-property{{#unless this.loadedAmmo}} item-property--empty{{/unless}}">
      {{#if this.loadedAmmo}}
        {{#if (ne this.loadedAmmo.damageOverride null)}}
        <strong>{{localize "sr4.ammo.damageOverride"}}</strong>
        {{ this.loadedAmmo.damageOverride }}
        {{else}}
        <strong>{{localize "sr4.ammo.damageBonus"}}</strong>
        {{#if (gte this.loadedAmmo.damageBonus 0)}}+{{/if}}{{ this.loadedAmmo.damageBonus }}
        {{/if}}
      {{/if}}
    </span>
    <span class="item-property{{#unless this.loadedAmmo.displayDamageTypeOverride}} item-property--empty{{/unless}}">
      {{#if this.loadedAmmo.displayDamageTypeOverride}}
      <strong>{{localize "sr4.ammo.damageTypeOverride"}}</strong>
      {{localize this.loadedAmmo.displayDamageTypeOverride}}
      {{/if}}
    </span>
    <span class="item-property{{#unless this.loadedAmmo}} item-property--empty{{/unless}}">
      {{#if this.loadedAmmo}}
      <strong>{{localize "sr4.ammo.apBonus"}}</strong>
      {{#if (gte this.loadedAmmo.apBonus 0)}}+{{/if}}{{ this.loadedAmmo.apBonus }}
      {{/if}}
    </span>
    <span class="item-property item-property--empty"></span>
    <span class="item-property{{#unless this.loadedAmmo}} item-property--empty{{/unless}}">
      {{#if this.loadedAmmo}}
      <strong>{{localize "sr4.ammo.quantity"}}</strong>
      {{ this.loadedAmmo.quantity }}
      {{/if}}
    </span>
  </div>
  {{/if}}
  {{/if}}
</div>
