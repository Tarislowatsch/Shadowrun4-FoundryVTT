<div class="metadata-container">
  <div class="character-row">
    {{> "actor-image"}}

    <div class="info-columns">
      <div class="meta-field">
        <label>{{localize 'sr4.metadata.characterName'}}</label>
        <input type="text" name="name" value="{{actor.name}}" data-dtype="String"/>
      </div>

      {{#each system.metaData}}
        {{#unless (eq @key 'age')}}
        <div class="meta-field">
          <label>{{localizeKey 'sr4.metadata' @key}}</label>
          {{#if (lookup ../textFields @key)}}
            <input type="text" name="system.metaData.{{@key}}" value="{{this}}" data-dtype="String" {{#unless ../editMode}}readonly{{/unless}} />
          {{else}}
            <input type="number" name="system.metaData.{{@key}}" value="{{this}}" data-dtype="Number" {{#unless ../editMode}}readonly{{/unless}} />
          {{/if}}
        </div>
        {{/unless}}
      {{/each}}
    </div>
  </div>
</div>
