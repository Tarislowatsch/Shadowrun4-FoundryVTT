<div class="tab bio {{ tab.cssClass }}" data-group="primary" data-tab="bio">
  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.bio.metatype'}}</h3>
      {{#unless metatypeItem}}
        {{#if editMode}}
          {{> item-create-btn btnAction="createItem" btnItemType="Metatype" btnTooltip="sr4.metatype.create"}}
        {{/if}}
      {{/unless}}
    </summary>
    {{#if metatypeItem}}
      {{#with metatypeItem}}
      {{> "metatype-card"}}
      {{/with}}
    {{else}}
      <p class="empty-list">{{localize 'sr4.metatype.noMetatype'}}</p>
    {{/if}}
  </details>

  {{#> collapsible-section title=(localize 'sr4.bio.physicalDescription')}}
    <div class="info-columns">
      {{> meta-field label='sr4.metadata.realName' name='system.descriptionAndNotes.realName' value=system.descriptionAndNotes.realName editMode=editMode}}
      {{> meta-field label='sr4.metadata.metatype' name='system.descriptionAndNotes.metatype' value=system.descriptionAndNotes.metatype editMode=editMode}}
      {{> meta-field label='sr4.metadata.gender' name='system.descriptionAndNotes.gender' value=system.descriptionAndNotes.gender editMode=editMode}}
      {{> meta-field label='sr4.metadata.age' name='system.metaData.age' value=system.metaData.age numeric=true editMode=editMode}}
      {{> meta-field label='sr4.metadata.height' name='system.descriptionAndNotes.height' value=system.descriptionAndNotes.height editMode=editMode}}
      {{> meta-field label='sr4.metadata.weight' name='system.descriptionAndNotes.weight' value=system.descriptionAndNotes.weight editMode=editMode}}
      {{> meta-field label='sr4.metadata.eyes' name='system.descriptionAndNotes.eyes' value=system.descriptionAndNotes.eyes editMode=editMode}}
      {{> meta-field label='sr4.metadata.hair' name='system.descriptionAndNotes.hair' value=system.descriptionAndNotes.hair editMode=editMode}}
      {{> meta-field label='sr4.metadata.skin' name='system.descriptionAndNotes.skin' value=system.descriptionAndNotes.skin editMode=editMode}}
    </div>
  {{/collapsible-section}}

  {{#> collapsible-section title=(localize 'sr4.bio.biography')}}
    <div class="item-textareas">
      {{> textarea-field label='sr4.bio.bio' name='system.descriptionAndNotes.bio' value=system.descriptionAndNotes.bio}}
      {{> textarea-field label='sr4.bio.notes' name='system.descriptionAndNotes.notes' value=system.descriptionAndNotes.notes}}
    </div>
  {{/collapsible-section}}

  {{#> collapsible-section title=(localize 'sr4.bio.connections') btnAction="createConnection" btnTooltip="sr4.connection.create"}}
    <table class="connections-table">
      <thead>
        <tr>
          <th>{{localize 'sr4.connection.name'}}</th>
          <th>{{localize 'sr4.connection.archetype'}}</th>
          <th class="num-col">{{localize 'sr4.connection.connection'}}</th>
          <th class="num-col">{{localize 'sr4.connection.groupConnection'}}</th>
          <th class="num-col">{{localize 'sr4.connection.loyalty'}}</th>
          <th class="type-col">{{localize 'sr4.connection.type'}}</th>
          {{#if editMode}}<th class="controls-col"></th>{{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each system.connections as |conn key|}}
        <tr class="connection-row" data-connection-key="{{key}}">
          <td><input type="text" name="{{concat 'system.connections.' key '.name'}}" value="{{conn.name}}" {{#unless ../editMode}}readonly{{/unless}} /></td>
          <td><input type="text" name="{{concat 'system.connections.' key '.archetype'}}" value="{{conn.archetype}}" {{#unless ../editMode}}readonly{{/unless}} /></td>
          <td class="num-col"><input type="number" data-dtype="Number" name="{{concat 'system.connections.' key '.connection'}}" value="{{conn.connection}}" {{#unless ../editMode}}readonly{{/unless}} /></td>
          <td class="num-col"><input type="number" data-dtype="Number" name="{{concat 'system.connections.' key '.groupConnection'}}" value="{{conn.groupConnection}}" {{#unless ../editMode}}readonly{{/unless}} /></td>
          <td class="num-col"><input type="number" data-dtype="Number" name="{{concat 'system.connections.' key '.loyalty'}}" value="{{conn.loyalty}}" {{#unless ../editMode}}readonly{{/unless}} /></td>
          <td class="type-col">
            <select name="{{concat 'system.connections.' key '.type'}}" {{#unless ../editMode}}disabled{{/unless}}>
              <option value="Contact" {{#if (eq conn.type 'Contact')}}selected{{/if}}>{{localize 'sr4.connection.contact'}}</option>
              <option value="Enemy" {{#if (eq conn.type 'Enemy')}}selected{{/if}}>{{localize 'sr4.connection.enemy'}}</option>
            </select>
          </td>
          {{#if ../editMode}}
          <td class="item-controls">
            <a data-action="deleteConnection" data-connection-key="{{key}}"
              data-tooltip="{{localize 'sr4.connection.delete'}}"><i class="fas fa-trash"></i></a>
          </td>
          {{/if}}
        </tr>
        {{else}}
        <tr>
          <td colspan="7" class="empty-list">{{localize 'sr4.connection.noConnections'}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  {{/collapsible-section}}

  {{#> collapsible-section title=(localize 'sr4.bio.qualities') btnAction="createItem" btnItemType="Quality" btnTooltip="sr4.quality.create"}}
    {{#> collapsible-subsection title=(localize 'sr4.quality.positive')}}
      {{#if positiveQualities}}
      <ul class="item-list">
        {{#each positiveQualities as |item|}}
        {{> "quality-card"}}
        {{/each}}
      </ul>
      {{else}}
      <p class="empty-list">{{localize 'sr4.quality.noQualities'}}</p>
      {{/if}}
    {{/collapsible-subsection}}

    {{#> collapsible-subsection title=(localize 'sr4.quality.negative')}}
      {{#if negativeQualities}}
      <ul class="item-list">
        {{#each negativeQualities as |item|}}
        {{> "quality-card"}}
        {{/each}}
      </ul>
      {{else}}
      <p class="empty-list">{{localize 'sr4.quality.noQualities'}}</p>
      {{/if}}
    {{/collapsible-subsection}}
  {{/collapsible-section}}
</div>
