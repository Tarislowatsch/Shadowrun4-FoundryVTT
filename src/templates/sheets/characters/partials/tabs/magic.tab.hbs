<div
  class="magic-card tab {{ tab.cssClass }}"
  data-group="primary"
  data-tab="magic"
>
  <div class="magic-grid">
    <div class="magic-column">
      <div class="magic-input">
        <label for="magician">{{localize "sr4.magic.magician"}}</label>
        <input
          type="checkbox"
          class="sr4-checkbox"
          id="magician"
          name="system.magic.magician"
          data-action="toggleMagician"
          {{checked
          system.magic.magician}}
        />
      </div>
      <div class="magic-input">
        <label for="adept">{{localize "sr4.magic.adept"}}</label>
        <input
          type="checkbox"
          class="sr4-checkbox"
          id="adept"
          name="system.magic.adept"
          data-action="toggleAdept"
          {{checked
          system.magic.adept}}
        />
      </div>
      {{#if system.magic.magician}}
      <div class="magic-input">
        <label for="tradition">{{localize "sr4.magic.tradition"}}</label>
        <select
          id="tradition"
          name="system.magic.tradition"
          data-dtype="String"
        >
          {{selectOptions traditions selected=system.magic.tradition localize=true}}
        </select>
      </div>
      {{> mentor-section context=mentorContext itemId=mentorItemId labelKey="sr4.mentor.label" category="Other"}}
      {{/if}}
    </div>

    {{#if system.magic.magician}}
    <div class="magic-column">
      <div class="magic-stat">
        <label>{{localize "sr4.magic.drainPool"}}:</label>
        <span>
          {{ system.sheetStats.WILLPOWER }}
          +
          {{lookup system.sheetStats system.magic.drainAttribute}}
        </span>
      </div>
      <div class="magic-input">
        <label
          for="drainAttribute"
          >{{localize "sr4.magic.drainAttribute"}}</label
        >
        <select
          id="drainAttribute"
          name="system.magic.drainAttribute"
          data-dtype="String"
        >
          {{selectOptions drainAttributes selected=system.magic.drainAttribute localize=true}}
        </select>
      </div>
      <div class="section-subtitle">
        {{localize "sr4.magic.drainboni.label"}}
      </div>
      <div class="magic-input">
        <label
          for="drainBonus"
          >{{localize "sr4.magic.drainboni.spellcasting"}}</label
        >
        <input
          type="number"
          id="drainBonus"
          name="system.magic.drainBonus"
          data-dtype="Number"
          value="{{ system.magic.drainBonus }}"
        />
      </div>
      <div class="magic-input">
        <label
          for="summoningDrainBonus"
          >{{localize "sr4.magic.drainboni.summoning"}}</label
        >
        <input
          type="number"
          id="summoningDrainBonus"
          name="system.magic.summoningDrainBonus"
          data-dtype="Number"
          value="{{ system.magic.summoningDrainBonus }}"
        />
      </div>
    </div>
    {{/if}}

    {{#if system.magic.adept}}
    <div class="magic-column">
      <div class="magic-stat">
        <label>{{localize "sr4.magic.powerpoints"}}:</label>
        <span
          class="{{#if (gt totalPowerCost system.sheetStats.MAGIC)}}over-limit{{/if}}"
        >
          {{ totalPowerCost }} / {{ system.sheetStats.MAGIC }}
        </span>
      </div>
    </div>
    {{/if}}
  </div>

  {{#if system.magic.magician}}
  {{> entity-affinities
    sectionLabel="sr4.magic.spiritAffinities.label"
    categories=spiritAffinityCategories
    idPrefix="spiritAffinity"
    namePrefix="system.magic.spiritAffinities"
    buttons=(array
      (object action="summonSpirit" icon="fas fa-ghost" label="sr4.magic.summon" tooltip="sr4.magic.summon")
      (object action="summonWatcher" icon="fas fa-eye" label="sr4.magic.summonWatcher" tooltip="sr4.magic.summonWatcher")
      (object action="banishSpirit" icon="fas fa-skull" label="sr4.magic.banish" tooltip="sr4.magic.banishHint")
      (object action="bindSpirit" icon="fas fa-link" label="sr4.ui.bindActor" tooltip="sr4.magic.bindSpiritHint")
    )
    createAction="createSpiritTemplate"
  }}

  {{#> collapsible-section title=(localize "sr4.magic.summonedSpirits")}}
    {{#if summonedSpirits.length}}
    <ul class="item-list linked-actor-list">
      {{#each summonedSpirits as |linked|}}
      {{> "linked-actor-card" linked}}
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-list">{{localize "sr4.spirit.noSpirits"}}</p>
    {{/if}}
  {{/collapsible-section}}

  {{#> collapsible-section title=(localize "sr4.magic.spells") btnAction="createItem" btnItemType="Spell" btnTooltip="sr4.magic.spells"}}
    {{#if spells}}
    <ul class="spell-list">
      {{#each spells as |spell|}}
      {{> "spell-card" spell}}
      {{/each}}
    </ul>
    {{else}}
    <p>{{localize "sr4.spell.noSpells"}}</p>
    {{/if}}
  {{/collapsible-section}}

  {{#> collapsible-section title=(localize "sr4.inventory.foci") btnAction="createItem" btnItemType="Focus" btnTooltip="sr4.item.create"}}
    {{#if foci}}
    <ul class="item-list">
      {{#each foci as |item|}}
      {{> "focus-card"}}
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-list">{{localize "sr4.focus.noFoci"}}</p>
    {{/if}}
  {{/collapsible-section}}
  {{/if}}

  {{#if system.magic.adept}}
  {{#> collapsible-section title=(localize "sr4.magic.powers") btnAction="createItem" btnItemType="Power" btnTooltip="sr4.magic.powers"}}
    {{#if powers}}
    <ul class="spell-list">
      {{#each powers as |power|}}
      {{> "power-card" power}}
      {{/each}}
    </ul>
    {{else}}
    <p>{{localize "sr4.power.nopowers"}}</p>
    {{/if}}
  {{/collapsible-section}}
  {{/if}}
</div>
