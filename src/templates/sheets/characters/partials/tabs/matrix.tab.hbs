<div
  class="matrix-card tab {{ tab.cssClass }}"
  data-group="primary"
  data-tab="matrix"
>
  <div class="magic-grid">
    <div class="magic-column">
      <div class="magic-input">
        <label for="technomancer">{{localize "sr4.matrix.technomancer"}}</label>
        <input
          type="checkbox"
          class="sr4-checkbox"
          id="technomancer"
          name="system.technomancy.technomancer"
          {{checked system.technomancy.technomancer}}
        />
      </div>
      <div class="magic-input">
        <label for="matrixSimMode">{{localize "sr4.matrix.simMode.label"}}</label>
        <select id="matrixSimMode" name="system.matrixSimMode" data-dtype="String" {{#unless editMode}}disabled{{/unless}}>
          {{#each simModeOptions as |opt|}}
          <option value="{{opt.value}}" {{#if (eq opt.value @root.system.matrixSimMode)}}selected{{/if}}>{{opt.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </div>

  {{#if isTechnomancer}}

  <div class="magic-grid">
    <div class="magic-column">
      <div class="magic-input">
        <label for="stream">{{localize "sr4.matrix.stream"}}</label>
        <select id="stream" name="system.technomancy.stream" data-dtype="String">
          {{selectOptions streams selected=system.technomancy.stream localize=true}}
        </select>
      </div>
      <div class="magic-input">
        <label for="fadingAttribute">{{localize "sr4.matrix.fadingAttribute"}}</label>
        <select id="fadingAttribute" name="system.technomancy.fadingAttribute" data-dtype="String">
          {{selectOptions fadingAttributes selected=system.technomancy.fadingAttribute localize=true}}
        </select>
      </div>
    </div>
    <div class="magic-column">
      <div class="magic-stat">
        <label>{{localize "sr4.matrix.fadingPool"}}:</label>
        <span>{{ fadingPool }}</span>
      </div>
      <div class="magic-input">
        <label for="compilingFadingBonus">{{localize "sr4.matrix.fadingboni.compiling"}}</label>
        <input
          type="number"
          id="compilingFadingBonus"
          name="system.technomancy.compilingFadingBonus"
          data-dtype="Number"
          value="{{ system.technomancy.compilingFadingBonus }}"
        />
      </div>
    </div>
  </div>

  <h3>{{localize "sr4.matrix.livingPersona"}}</h3>
  <table class="item-stats-table">
    <thead>
      <tr>
        <th>{{localize "sr4.matrix.attribute"}}</th>
        <th>{{localize "sr4.skills.rating"}}</th>
        <th>{{localize "sr4.matrix.bonus"}}</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{localize "sr4.matrix.response"}}</td>
        <td>{{ livingPersona.response }}</td>
        <td>
          <input
            type="number"
            name="system.livingPersona.responseBonus"
            value="{{ system.livingPersona.responseBonus }}"
          />
        </td>
      </tr>
      <tr>
        <td>{{localize "sr4.matrix.signal"}}</td>
        <td>{{ livingPersona.signal }}</td>
        <td>
          <input
            type="number"
            name="system.livingPersona.signalBonus"
            value="{{ system.livingPersona.signalBonus }}"
          />
        </td>
      </tr>
      <tr>
        <td>{{localize "sr4.matrix.firewall"}}</td>
        <td>{{ livingPersona.firewall }}</td>
        <td>
          <input
            type="number"
            name="system.livingPersona.firewallBonus"
            value="{{ system.livingPersona.firewallBonus }}"
          />
        </td>
      </tr>
      <tr>
        <td>{{localize "sr4.matrix.system"}}</td>
        <td>{{ livingPersona.system }}</td>
        <td>
          <input
            type="number"
            name="system.livingPersona.systemBonus"
            value="{{ system.livingPersona.systemBonus }}"
          />
        </td>
      </tr>
      <tr>
        <td>{{localize "sr4.matrix.biofeedbackFilter"}}</td>
        <td>{{ livingPersona.biofeedbackFilter }}</td>
        <td>
          <input
            type="number"
            name="system.livingPersona.biofeedbackFilterBonus"
            value="{{ system.livingPersona.biofeedbackFilterBonus }}"
          />
        </td>
      </tr>
      <tr>
        <td>{{localize "sr4.matrix.vrMatrixInitiative"}}</td>
        <td>{{ livingPersona.vrMatrixInitiative }}</td>
        <td>—</td>
      </tr>
      <tr>
        <td>{{localize "sr4.matrix.vrMatrixInitiativePasses"}}</td>
        <td>{{ livingPersona.vrMatrixInitiativePasses }}</td>
        <td>—</td>
      </tr>
    </tbody>
  </table>

  {{> entity-affinities
    sectionLabel="sr4.magic.spriteAffinities.label"
    categories=spriteAffinityCategories
    idPrefix="spriteAffinity"
    namePrefix="system.technomancy.spriteAffinities"
    btnAction="compileSprite"
    btnIcon="fas fa-microchip"
    btnLabel="sr4.magic.compile"
    createAction="createSpriteTemplate"
  }}

  {{#> collapsible-section title=(localize "sr4.matrix.compiledSprites")}}
    {{#if summonedSprites.length}}
    <ul class="item-list linked-actor-list">
      {{#each summonedSprites as |linked|}}
      {{> "linked-actor-card" linked}}
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-list">{{localize "sr4.sprite.noSprites"}}</p>
    {{/if}}
  {{/collapsible-section}}

  <div class="magic-section-subtitle">
    <h3>{{localize "sr4.matrix.complexForms"}}</h3>
    <button
      type="button"
      class="thread-button"
      data-action="threadComplexForm"
      data-tooltip="{{localize 'sr4.matrix.threadingHint'}}"
    >
      <i class="fas fa-dice-d20"></i>
      {{localize "sr4.matrix.threading"}}
    </button>
  </div>
  {{#if complexForms}}
  <ul class="item-list">
    {{#each complexForms as |form|}}
    {{> "program-card"}}
    {{/each}}
  </ul>
  {{else}}
  <p>{{localize "sr4.matrix.noComplexForms"}}</p>
  {{/if}}

  {{/if}}

  <h3>{{localize "sr4.matrix.commlinks"}}</h3>
  {{#if commlinks}}
  <ul class="item-list">
    {{#each commlinks as |item|}}
    {{> "commlink-card"}}
    {{/each}}
  </ul>
  {{else}}
  <p>{{localize "sr4.commlink.noCommlinks"}}</p>
  {{/if}}

  <h3>{{localize "sr4.matrix.software"}}</h3>
  {{#if programs}}
  <ul class="item-list">
    {{#each programs as |item|}}
    {{> "program-card"}}
    {{/each}}
  </ul>
  {{else}}
  <p>{{localize "sr4.matrix.noSoftware"}}</p>
  {{/if}}
</div>
