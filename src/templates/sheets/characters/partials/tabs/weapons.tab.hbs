<div
  class="tab weapons {{ tab.cssClass }}"
  data-group="primary"
  data-tab="weapons"
>
  {{#if editMode}}
  <div style="margin-bottom: 0.5rem;">
    {{> item-create-btn btnAction="openCreateItemDialog" btnTooltip="sr4.item.create"}}
  </div>
  {{/if}}
  {{#if weapons}}
  <ul class="weapon-list">
    {{#each weapons as |weapon|}}
    {{> "weapon-card"}}
    {{/each}}
  </ul>
  {{else}}
  <p>{{localize 'sr4.weapon.noWeapons'}}</p>
  {{/if}}
</div>
