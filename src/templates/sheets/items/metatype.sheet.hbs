<div class="item-sheet-body">
  {{> "item-sheet-header" nameKey="sr4.item.name"}}

  <table class="item-stats-table">
    <thead>
      <tr>
        <th>{{localize 'sr4.metatype.category'}}</th>
        <th>{{localize 'sr4.metatype.bp'}}</th>
        <th>{{localize 'sr4.metatype.baseMetatype'}}</th>
        <th>{{localize 'sr4.metatype.movement'}}</th>
        <th>{{localize 'sr4.metatype.reach'}}</th>
        <th>{{localize 'sr4.item.source'}}</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          <select name="system.category">
            <option value="Metahuman" {{#if (eq system.category "Metahuman")}}selected{{/if}}>Metahuman</option>
            <option value="Sapient Critter" {{#if (eq system.category "Sapient Critter")}}selected{{/if}}>Sapient Critter</option>
            <option value="Shapeshifter" {{#if (eq system.category "Shapeshifter")}}selected{{/if}}>Shapeshifter</option>
            <option value="Special" {{#if (eq system.category "Special")}}selected{{/if}}>Special</option>
          </select>
        </td>
        <td><input type="number" name="system.bp" value="{{ system.bp }}" /></td>
        <td><input type="text" name="system.baseMetatype" value="{{ system.baseMetatype }}" /></td>
        <td><input type="text" name="system.movement" value="{{ system.movement }}" /></td>
        <td><input type="number" name="system.reach" value="{{ system.reach }}" /></td>
        <td><input type="text" name="system.source" value="{{ system.source }}" /></td>
      </tr>
    </tbody>
  </table>

  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.metatype.attributeLimits'}}</h3>
    </summary>
    <table class="item-stats-table metatype-attributes-table">
      <thead>
        <tr>
          <th>{{localize 'sr4.metatype.attribute'}}</th>
          <th>{{localize 'sr4.metatype.min'}}</th>
          <th>{{localize 'sr4.metatype.max'}}</th>
          <th>{{localize 'sr4.metatype.aug'}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each attributeRows as |row|}}
        <tr>
          <td>{{localize row.label}}</td>
          <td><input type="number" name="system.attributes.{{row.key}}.min" value="{{row.min}}" /></td>
          <td><input type="number" name="system.attributes.{{row.key}}.max" value="{{row.max}}" /></td>
          <td><input type="number" name="system.attributes.{{row.key}}.aug" value="{{row.aug}}" /></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </details>

  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.metatype.armorBonus'}}</h3>
    </summary>
    <table class="item-stats-table">
      <thead>
        <tr>
          <th>{{localize 'sr4.armor.ballistic'}}</th>
          <th>{{localize 'sr4.armor.impact'}}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><input type="number" name="system.armorBallistic" value="{{ system.armorBallistic }}" /></td>
          <td><input type="number" name="system.armorImpact" value="{{ system.armorImpact }}" /></td>
        </tr>
      </tbody>
    </table>
  </details>

  {{#if system.qualities.positive.length}}
  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.quality.positive'}}</h3>
    </summary>
    <ul class="metatype-quality-list">
      {{#each system.qualities.positive as |q|}}
      <li>{{q}}</li>
      {{/each}}
    </ul>
  </details>
  {{/if}}

  {{#if system.qualities.negative.length}}
  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.quality.negative'}}</h3>
    </summary>
    <ul class="metatype-quality-list">
      {{#each system.qualities.negative as |q|}}
      <li>{{q}}</li>
      {{/each}}
    </ul>
  </details>
  {{/if}}

  {{#if system.powers.length}}
  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.metatype.powers'}}</h3>
    </summary>
    <ul class="metatype-quality-list">
      {{#each system.powers as |p|}}
      <li>{{p}}</li>
      {{/each}}
    </ul>
  </details>
  {{/if}}

  {{#if system.optionalPowers.length}}
  <details class="inventory-section collapsible-section" open>
    <summary class="collapsible-header">
      <i class="fas fa-chevron-right collapse-icon"></i>
      <h3>{{localize 'sr4.metatype.optionalPowers'}}</h3>
    </summary>
    <ul class="metatype-quality-list">
      {{#each system.optionalPowers as |p|}}
      <li>{{p}}</li>
      {{/each}}
    </ul>
  </details>
  {{/if}}

  {{> "item-textareas"}}
</div>
