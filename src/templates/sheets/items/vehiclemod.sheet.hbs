
  <div class="item-sheet-body">
    {{> "item-sheet-header" nameKey="sr4.vehiclemod.name"}}

    <table class="item-stats-table">
      <thead>
        <tr>
          <th>{{localize 'sr4.vehiclemod.handlingBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.speedBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.accelBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.armorBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.sensorBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.bodyBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.pilotBonus'}}</th>
          <th>{{localize 'sr4.vehiclemod.slotCost'}}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><input type="number" name="system.handlingBonus" value="{{ system.handlingBonus }}" /></td>
          <td><input type="number" name="system.speedBonus" value="{{ system.speedBonus }}" /></td>
          <td><input type="number" name="system.accelBonus" value="{{ system.accelBonus }}" /></td>
          <td><input type="number" name="system.armorBonus" value="{{ system.armorBonus }}" /></td>
          <td><input type="number" name="system.sensorBonus" value="{{ system.sensorBonus }}" /></td>
          <td><input type="number" name="system.bodyBonus" value="{{ system.bodyBonus }}" /></td>
          <td><input type="number" name="system.pilotBonus" value="{{ system.pilotBonus }}" /></td>
          <td><input type="number" name="system.slotCost" value="{{ system.slotCost }}" /></td>
        </tr>
      </tbody>
    </table>

    <table class="item-stats-table">
      <thead>
        <tr>
          <th>{{localize 'sr4.item.rating'}}</th>
          <th>{{localize 'sr4.item.avail'}}</th>
          <th>{{localize 'sr4.item.legality'}}</th>
          <th>{{localize 'sr4.item.cost'}}</th>
          {{> item-source-header}}
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><input type="number" name="system.rating" value="{{ system.rating }}" placeholder="—" /></td>
          <td><input type="number" name="system.avail" value="{{ system.avail }}" /></td>
          <td><input type="text" name="system.legality" value="{{ system.legality }}" /></td>
          <td><input type="number" name="system.cost" value="{{ system.cost }}" /></td>
          {{> item-source-cell value=system.source}}
        </tr>
      </tbody>
    </table>

    {{> "item-textareas"}}
  </div>
