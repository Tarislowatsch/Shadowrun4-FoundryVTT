<div
  class="item-card"
  data-item-id="{{ this._id }}"
  id="{{ item._id }}"
  title="{{ item.system.description }}"
>
  <div class="item-row">
    <span class="item-name">{{ item.name }}</span>

    <span class="item-type"
      >{{localize "sr4.item.type"}}: {{ item.system.type }}</span
    >

    <span class="item-grade"
      >{{localize "sr4.item.grade"}}: {{ item.system.grade }}</span
    >

    <span class="item-rating"
      >{{localize "sr4.item.rating"}}: {{ item.system.rating }}</span
    >

    <span class="item-essence"
      >{{localize "sr4.item.essence"}}: {{ item.system.essence }}</span
    >

    <span class="item-essence-effective">
      {{localize "sr4.item.essenceActual"}}: {{ item.system.essenceActual }}
    </span>

    <span class="item-availability">{{ item.system.avail }}</span>
    <span class="item-legality">{{ item.system.legality }}</span>
    <span class="item-cost">{{ item.system.cost }}</span>

    <button class="item-edit" data-action="edit-item" data-tooltip="Bearbeiten">
      <i class="fas fa-edit"></i>
    </button>
    <button class="item-delete" data-action="deleteItem" data-tooltip="">
      <i class="fas fa-trash"></i>
    </button>
  </div>
</div>
