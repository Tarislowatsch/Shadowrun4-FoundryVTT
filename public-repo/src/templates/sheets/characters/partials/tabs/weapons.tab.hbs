<div
  class="tab weapons {{ tab.cssClass }}"
  data-group="primary"
  data-tab="weapons"
>
  {{#if weapons}}
  <ul class="weapon-list">
    {{#each weapons as |weapon|}}
    {{> weapon-card weapon shootingmodes=../shootingmodes attackskills=../attackskills meleeDmgBonus=../meleeDmgBonus}}
    {{/each}}
  </ul>
  {{else}}
  <p>{{localize 'sr4.weapon.noWeapons'}}</p>
  {{/if}}
</div>
